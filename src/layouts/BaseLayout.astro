---
import '../styles/global.css';
import { getAllCategories } from '../lib/categories';
import IntegrationSwitcher from '../components/IntegrationSwitcher';
import SearchBar from '../components/SearchBar';
import ChatAssistant from '../components/ChatAssistant';
import Walkthrough from '../components/Walkthrough';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Pikle example ecommerce store' } = Astro.props;
const categories = await getAllCategories();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="pikle:key" content={import.meta.env.PUBLIC_PIKLE_SDK_KEY} />

    <script is:inline>
      (function() {
        var enabled = true;
        try { enabled = sessionStorage.getItem('pikle-integrations-enabled') !== 'false'; } catch(e) {}
        document.documentElement.classList.toggle('integrations-on', enabled);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="/" class="site-header__logo">Pikle ecommerce demo</a>
        <SearchBar client:only="react" />
        <nav class="site-header__nav">
          {categories.map((cat) => (
            <a href={`/${cat.slug}`}>{cat.name}</a>
          ))}
          <a href="/cart" class="site-header__cart">Cart</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <IntegrationSwitcher client:only="react" />
    <ChatAssistant client:only="react" />
    <Walkthrough client:only="react" />

    <script>
      import { INTEGRATIONS_EVENT } from '../lib/integrations';
      document.addEventListener(INTEGRATIONS_EVENT, (e: Event) => {
        document.documentElement.classList.toggle(
          'integrations-on',
          (e as CustomEvent<{ enabled: boolean }>).detail.enabled
        );
      });
    </script>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <span>Pikle ecommerce demo — not a real store.</span>
        <a href="/credits">Image credits</a>
      </div>
    </footer>

    <!-- Pikle JS SDK embed (site-wide) -->
    <div id="pikle-root" data-app-key={import.meta.env.PUBLIC_PIKLE_SDK_KEY}></div>
    <script>
      import { isIntegrationsEnabled, INTEGRATIONS_EVENT } from '../lib/integrations';

      let loaded = false;

      function loadPikleSdk() {
        if (loaded) return;
        loaded = true;

        const appKey = document.getElementById('pikle-root')?.dataset.appKey;

        (function (w: any, id: string, c: unknown) {
          w[id] = w[id] || (w[id] = []);
          w[id].push(c);
        })(window, 'PIKLE', {
          appKey,
          version: 'v1.0',
        });

        const script = document.createElement('script');
        script.crossOrigin = 'anonymous';
        script.src = 'https://connect.pikle.online/jssdk/v1.0/init.js';
        document.body.appendChild(script);
      }

      if (isIntegrationsEnabled()) loadPikleSdk();

      document.addEventListener(INTEGRATIONS_EVENT, (e: Event) => {
        if ((e as CustomEvent<{ enabled: boolean }>).detail.enabled) loadPikleSdk();
      });
    </script>
  </body>
</html>
