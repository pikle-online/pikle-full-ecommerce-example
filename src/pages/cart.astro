---
import BaseLayout from '../layouts/BaseLayout.astro';
import CartPage from '../components/CartPage';
import { getAllCategories, getAllProducts } from '../lib/categories';

const categories = await getAllCategories();
const allProducts = (
  await Promise.all(categories.map((c) => getAllProducts(c.slug)))
).flat();
---

<BaseLayout title="Your Cart — Pikle ecommerce demo">
  <div class="section">
    <div class="container">
      <CartPage client:load allProducts={allProducts} />
    </div>
  </div>
</BaseLayout>

<style>
  :global(.cart-layout) {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 48px;
    align-items: start;
  }

  @media (max-width: 768px) {
    :global(.cart-layout) {
      grid-template-columns: 1fr;
    }
  }

  :global(.cart-heading) {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-primary);
    margin-bottom: 32px;
  }

  :global(.cart-notice) {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    padding: 12px 16px;
    font-size: 0.9rem;
    color: var(--color-text);
    margin-bottom: 24px;
    border-radius: var(--radius);
  }

  :global(.cart-empty) {
    color: var(--color-text-muted);
    padding: 48px 0;
  }

  :global(.cart-list) {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  :global(.cart-item) {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 20px;
    align-items: start;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-border);
  }

  :global(.cart-item__image) {
    aspect-ratio: 3/4;
    background-color: var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  :global(.cart-item__image img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.cart-item__image-placeholder) {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  :global(.cart-item__info) {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  :global(.cart-item__name) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }

  :global(.cart-item__name:hover) {
    text-decoration: underline;
  }

  :global(.cart-item__price) {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  :global(.cart-item__qty) {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  :global(.qty-btn) {
    width: 28px;
    height: 28px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text);
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s;
  }

  :global(.qty-btn:hover) {
    border-color: var(--color-primary);
  }

  :global(.cart-item__remove) {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 0.85rem;
    padding: 4px;
    transition: color 0.2s;
  }

  :global(.cart-item__remove:hover) {
    color: var(--color-primary);
  }

  :global(.cart-summary) {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 88px;
  }

  :global(.cart-summary__heading) {
    font-size: 1.1rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  :global(.cart-summary__lines) {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  :global(.cart-summary__line) {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  :global(.cart-summary__total) {
    display: flex;
    justify-content: space-between;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-primary);
    border-top: 1px solid var(--color-border);
    padding-top: 16px;
  }

  :global(.cart-summary__checkout) {
    width: 100%;
    justify-content: center;
    opacity: 0.5;
    cursor: not-allowed;
  }

  :global(.cart-summary__continue) {
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: underline;
  }
</style>
